# Server
PORT=4000
NODE_ENV=development
API_BASE_URL=http://localhost:4000

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth (used to verify Google Sign-In ID tokens from the mobile app)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# OTP (mocked - in dev the OTP is always logged to the console and equals 123456)
OTP_EXPIRES_IN_MINUTES=5
OTP_STATIC_DEV_CODE=123456

# Cloudinary (image storage for avatars, workout media, community posts)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Firebase Cloud Messaging (push notifications)
FCM_SERVER_KEY=your_fcm_server_key
FCM_PROJECT_ID=your_fcm_project_id

# CORS
CORS_ORIGIN=*

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
