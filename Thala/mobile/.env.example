# Base URL of the Thala backend API (see /backend).
# On a physical device or emulator, "localhost" refers to the device itself,
# so point this at your machine's LAN IP or a tunnel, e.g. http://192.168.1.20:4000/api/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1

# Google OAuth Web Client ID used by expo-auth-session for Google Sign-In
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
